generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Роли пользователей
enum Role {
  user
  manager
  admin
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  CANCELLED
  POSTPONED
}

// 1. ПОЛЬЗОВАТЕЛИ
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?  
  role      Role     @default(user)
  createdAt DateTime @default(now())

  // Связь: Админ может создавать свои лиги
  createdLeagues League[]
}

// 2. ЛИГИ (ТОП-5 или кастомные от Админа)
model League {
  id      String  @id @default(cuid())
  name    String  @unique // Например: "Premier League"
  logoUrl String?

  // Флаг: true = создана админом, false = из внешнего API
  isCustom Boolean @default(false)
  externalId String?  @unique // ID из football-data.org (например, "PL")

  // Связь с админом, который её создал (может быть null для внешних лиг)
  createdBy String?
  creator   User?   @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  teams Team[]
  standings Standing[]
  matches   Match[]
  
  createdAt DateTime   @default(now())
}

// 3. КОМАНДЫ
model Team {
  id      String  @id @default(cuid())
  name    String  
  logoUrl String?

  // Связь: Команда принадлежит одной лиге
  leagueId  String
  league    League     @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  externalId String?   @unique
  standings Standing[]
  players   Player[]
  createdAt DateTime   @default(now())

  homeMatches Match[] @relation("HomeMatches")
  awayMatches Match[] @relation("AwayMatches")

  @@unique([name, leagueId])
}

// 4. ИГРОКИ (Состав команды)
model Player {
  id        String   @id @default(cuid())
  name      String
  number    Int?
  position  String?
  photoUrl  String?
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([teamId, number])
}

// 5. ТУРНИРНАЯ ТАБЛИЦА (Положение команды)
model Standing {
  id String @id @default(cuid())

  // Связь: 1 запись таблицы = 1 команда
  teamId String @unique
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  leagueId String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  // Статистика
  played         Int @default(0) // Матчей сыграно
  wins           Int @default(0) // Побед
  draws          Int @default(0) // Ничьих
  losses         Int @default(0) // Поражений
  goalsFor       Int @default(0) // Забито (Goals For)
  goalsAgainst   Int @default(0) // Пропущено (Goals Against)
  goalDifference Int @default(0) // GD = GF - GA

  points Int @default(0) // Очки

  createdAt DateTime @default(now())
}

model Match {
  id        String      @id @default(cuid())
  externalId String?    @unique
  
  homeTeamId String
  awayTeamId String
  
  // Отношения к командам (множественные связи)
  homeTeam  Team        @relation("HomeMatches", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam  Team        @relation("AwayMatches", fields: [awayTeamId], references: [id], onDelete: Cascade)
  
  leagueId  String
  league    League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  homeScore Int?        @default(0)
  awayScore Int?        @default(0)
  
  status    MatchStatus @default(SCHEDULED)
  date      DateTime

  stage     String? 

  createdAt DateTime    @default(now())
}